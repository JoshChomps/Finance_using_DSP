# FinSignal Suite Environment Configuration

# API Configuration
PORT=8000
HOST=0.0.0.0

# Engine Configuration
# Path to where data should be cached locally.
# In Docker, this should match the volume mount point.
FIN_DATA_CACHE=/app/data/cache

# Optional: Add external API keys here as the suite grows
# POLYGON_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
